export async function getStaticPaths() {
  const media = await getAllMedia();
  return media.map((m: Media) => ({
    params: { slug: m.slug },
    props: { media: m }
  }));
}

const { slug } = Astro.params;
const media = await getMediaBySlug(slug);

if (!media) {
  return Astro.redirect('/404');
}
