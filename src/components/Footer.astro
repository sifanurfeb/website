<li><a class="text-[#546067] dark:text-slate-500 hover:text-[#005066] transition-colors hover:translate-x-1 inline-block font-['Plus_Jakarta_Sans'] text-sm uppercase tracking-wider" href="#">Privacy Policy</a></li>
